# ==============================================================================
# .GITIGNORE - Resume Analyzer & JD Matcher Version Control Safeguards
# Capstone Project Repository Strategy
# ==============================================================================

# --- Python Runtime & Bytecode Caches ---
__pycache__/                      # Python compiled source file cache directories
*.py[cod]                        # Individual compiled bytecodes (.pyc, .pyd)

# --- Isolated Development Environments ---
.venv/                           # Primary local application virtual environment
venv/                            # Alternative local virtual environment directory

# --- Secure Credentials & Configuration ---
.env                             # Local private workspace secrets (GROQ_API_KEY)

# --- IDE Profiles & Operating System Files ---
.vscode/                         # Visual Studio Code workspace settings configurations
.DS_Store                        # Apple macOS background system files
